# Root-level ignores. Each subproject (chat-agent-backend, chat-agent-frontend)
# also has its own .gitignore that applies to its subtree.

# Dependencies (defense-in-depth; subprojects ignore these too)
node_modules/

# Environment / secrets — only *.example templates are tracked
.env
.env.*
!.env*.example

# Redis snapshot / append-only files (created when running Redis locally)
*.rdb
*.aof
dump.rdb

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
